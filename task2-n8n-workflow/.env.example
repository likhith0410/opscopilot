# Copy to .env (next to docker-compose.yml) and fill in.
# These are read by docker-compose.yml and exposed to the n8n workflows
# as $env.SHEETS_DOC_ID etc.

# Google Sheet document ID (the long string in the sheet URL between /d/ and /edit)
SHEETS_DOC_ID=

# Trello list ID where high-urgency cards are created
TRELLO_LIST_ID=

# From-address for the normal-urgency confirmation email
SMTP_FROM_EMAIL=support@yourdomain.com

# Slack Incoming Webhook URL (https://hooks.slack.com/services/...) for alerts + digest
SLACK_WEBHOOK_URL=
