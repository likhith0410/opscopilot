      "id": "webhook-intake",
      "name": "Webhook: Lead Intake",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [180, 400],
      "webhookId": "lead-intake"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Validation + lightweight spam detection.\n// Required: name, email, message, urgency, product.  company is optional.\nconst input = $json.body ?? $json;\n\nconst REQUIRED = ['name', 'email', 'message', 'urgency', 'product'];\nconst missing = REQUIRED.filter(f => !input[f] || String(input[f]).trim() === '');\n\nconst emailRe = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nconst emailOk = input.email && emailRe.test(String(input.email).trim());\n\nconst urgencyOk = ['high', 'normal'].includes(String(input.urgency || '').toLowerCase());\n\nconst SPAM_KEYWORDS = ['viagra', 'crypto pump', 'guaranteed roi', 'click here to win', 'bit.ly', 'free money', 'wire transfer', 'forex signals'];\nconst messageLower = String(input.message || '').toLowerCase();\nconst spamHits = SPAM_KEYWORDS.filter(k => messageLower.includes(k));\nconst tooManyLinks = (messageLower.match(/https?:\\/\\//g) || []).length > 2;\nconst allCaps = input.message && input.message.length > 20 && input.message === String(input.message).toUpperCase();\nconst suspiciousTLD = /\\.(ru|tk|ml|cn|xyz)$/i.test(String(input.email || ''));\n\nconst isSpam = spamHits.length > 0 || tooManyLinks || allCaps || suspiciousTLD;\n\nconst errors = [];\nif (missing.length) errors.push(`missing fields: ${missing.join(', ')}`);\nif (!emailOk) errors.push('email is malformed');\nif (!urgencyOk) errors.push('urgency must be \"high\" or \"normal\"');\nif (isSpam) errors.push(`spam-like content (keywords: ${spamHits.join('|') || 'none'}, links>2: ${tooManyLinks}, all-caps: ${allCaps}, suspicious-tld: ${suspiciousTLD})`);\n\nconst valid = errors.length === 0;\n\nreturn [{\n  json: {\n    name: input.name,\n    email: input.email,\n    company: input.company || '',\n    message: input.message,\n    urgency: String(input.urgency || '').toLowerCase(),\n    product: input.product,\n    valid,\n    errors,\n    received_at: new Date().toISOString(),\n    spam_signals: { spamHits, tooManyLinks, allCaps, suspiciousTLD }\n  }\n}];"
      },
      "id": "validate",
      "name": "Validate + Spam Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
          "conditions": [
