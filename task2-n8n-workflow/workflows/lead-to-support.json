    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Enrich: use company if provided; else infer from email domain (skip public providers).\nconst PUBLIC_DOMAINS = new Set(['gmail.com','yahoo.com','outlook.com','hotmail.com','protonmail.com','icloud.com','aol.com','live.com']);\nconst lead = { ...$json };\nlet company = (lead.company || '').trim();\nlet source;\nif (company) {\n  source = 'provided';\n} else {\n  const domain = String(lead.email).split('@')[1] || '';\n  if (domain && !PUBLIC_DOMAINS.has(domain.toLowerCase())) {\n    const root = domain.split('.')[0];\n    company = root.charAt(0).toUpperCase() + root.slice(1);\n    source = 'inferred-from-email';\n  } else {\n    company = '(individual)';\n    source = 'public-domain-fallback';\n  }\n}\nlead.company = company;\nlead.company_source = source;\nreturn [{ json: lead }];"
      },
      "id": "enrich",
      "name": "Enrich Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 280]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Idempotency key = sha256(lower(email) | product | UTC-date)[0:32].\n// A webhook replay on the same day collapses to one stored record.\nconst crypto = require('crypto');\nconst lead = { ...$json };\nconst today = new Date().toISOString().slice(0, 10);\nconst basis = `${String(lead.email).toLowerCase().trim()}|${String(lead.product).trim()}|${today}`;\nlead.idempotency_key = crypto.createHash('sha256').update(basis).digest('hex').slice(0, 32);\nlead.idempotency_basis = basis;\nreturn [{ json: lead }];"
      },
      "id": "idempotency",
      "name": "Compute Idempotency Key",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1140, 280]
    },
    {
      "parameters": {
        "operation": "lookup",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.SHEETS_DOC_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "Leads" },
        "filtersUI": {
          "values": [
            { "lookupColumn": "idempotency_key", "lookupValue": "={{ $json.idempotency_key }}" }
          ]
        },
        "options": { "returnAllMatches": false }
