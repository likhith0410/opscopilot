      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Merge lead with lookup result. Sheets 'lookup' returns the matched row (with row_number)\n// or nothing when there's no match.\nconst lead = $('Compute Idempotency Key').first().json;\nconst lookup = $input.all();\nconst found = lookup.length > 0 && lookup[0].json && lookup[0].json.idempotency_key;\nreturn [{\n  json: {\n    ...lead,\n    duplicate: Boolean(found),\n    existing_row_number: found ? (lookup[0].json.row_number ?? null) : null\n  }\n}];"
      },
      "id": "merge-lookup",
      "name": "Merge Lookup Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1620, 280]
